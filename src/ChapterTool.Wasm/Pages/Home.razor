@page "/"
@implements IDisposable
@using System.Text
@using System.Text.Json
@inject WasmWorkspace Workspace
@inject WasmLocalizer L
@inject IJSRuntime Js

<PageTitle>@L.T("App.Title")</PageTitle>

<div id="chaptertool-shell"
     class="shell @(isDragOver ? "drag-over" : null)"
     tabindex="0"
     @onkeydown="OnKeyDownAsync"
     @onclick="OnShellClick">
    <div class="main">
        <!-- Top: load/save + clip + frame tools (Avalonia zone) -->
        <div class="top-bar">
            <div class="top-actions">
                <div class="load-group">
                    <button type="button"
                            class="primary"
                            disabled="@Workspace.IsBusy"
                            @onclick="TriggerLoad"
                            @oncontextmenu="OpenLoadContextMenu"
                            @oncontextmenu:preventDefault
                            title="@L.T("Title.Load")">
                        @L.T("Action.Load")
                    </button>
                </div>
                <button type="button"
                        class="primary"
                        disabled="@(!Workspace.CanSave)"
                        @onclick="SaveAsync"
                        title="@L.T("Title.Save")">
                    @L.T("Action.Save")
                </button>
                <InputFile id="loadFileInput"
                           class="hidden-file"
                           OnChange="OnFileSelected"
                           accept=".txt,.vtt,.xml,.cue,.mpls,.ifo,.csv,text/*,application/xml" />
                <InputFile id="appendMplsInput"
                           class="hidden-file"
                           OnChange="OnAppendMplsSelected"
                           accept=".mpls,application/octet-stream" />
                <InputFile id="templateFileInput"
                           class="hidden-file"
                           OnChange="OnTemplateSelected"
                           accept=".txt,.text,text/*" />
            </div>

            <div class="top-clip">
                @if (Workspace.IsClipSelectionVisible)
                {
                    <select class="clip-box"
                            value="@Workspace.SelectedClipId"
                            disabled="@Workspace.IsBusy"
                            @onchange="OnClipChanged"
                            @oncontextmenu="OpenClipContextMenu"
                            @oncontextmenu:preventDefault
                            title="@L.T("Label.Clip")">
                        @foreach (var clip in Workspace.ClipOptions)
                        {
                            <option value="@clip.Id">@clip.DisplayText</option>
                        }
                    </select>
                }
            </div>

            <div class="top-tools">
                <div class="top-tool-actions">
                    <label class="check">
                        <input type="checkbox"
                               checked="@roundFrames"
                               disabled="@(Workspace.IsBusy || Workspace.IsChapterGridEmpty)"
                               @onchange="OnRoundFramesChanged" />
                        @L.T("Label.RoundFrames")
                    </label>
                    <button type="button"
                            class="icon-button tool-icon-button"
                            disabled="@(!Workspace.CanPreview)"
                            @onclick="PreviewAsync"
                            title="@L.T("Title.Preview")"
                            aria-label="@L.T("Action.Preview")">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z" />
                            <circle cx="12" cy="12" r="2.75" />
                        </svg>
                    </button>
                    <button type="button"
                            class="icon-button tool-icon-button"
                            disabled="@(!Workspace.CanRefreshRows)"
                            @onclick="RefreshRows"
                            title="@L.T("Title.Refresh")"
                            aria-label="@L.T("Action.Refresh")">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M20 11a8 8 0 0 0-14.9-3.9L3 9" />
                            <path d="M3 4v5h5" />
                            <path d="M4 13a8 8 0 0 0 14.9 3.9L21 15" />
                            <path d="M21 20v-5h-5" />
                        </svg>
                    </button>
                    <button type="button"
                            class="icon-button"
                            @onclick="OpenSettings"
                            title="@L.T("Action.Settings")"
                            aria-label="@L.T("Action.Settings")">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M12 8.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Z" />
                            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.09a2 2 0 0 1 1 1.74v.5a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.38a2 2 0 0 0-.73-2.73l-.15-.09a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2Z" />
                        </svg>
                    </button>
                </div>
                <select class="fps-box"
                        value="@selectedFrameRateIndex"
                        disabled="@(Workspace.IsBusy || Workspace.IsChapterGridEmpty)"
                        @onchange="OnFrameRateChanged"
                        @oncontextmenu="OpenFrameRateContextMenu"
                        @oncontextmenu:preventDefault
                        title="@L.T("Label.FrameRate")">
                    @if (Workspace.FrameRateChoices.Count == 0)
                    {
                        <option value="0">—</option>
                    }
                    else
                    {
                        @foreach (var choice in Workspace.FrameRateChoices)
                        {
                            <option value="@choice.Index">@choice.DisplayName</option>
                        }
                    }
                </select>
            </div>
        </div>

        <!-- Center: chapter grid -->
        <div class="grid-zone">
            @if (!string.IsNullOrEmpty(Workspace.SourcePath))
            {
                <div class="path-line" title="@Workspace.SourcePath">
                    @Workspace.SourcePath
                    @if (Workspace.FramesPerSecond > 0)
                    {
                        <span class="path-fps"> · @Workspace.FramesPerSecondDisplay fps</span>
                    }
                </div>
            }

            <div class="grid-wrap">
                @if (Workspace.IsChapterGridEmpty)
                {
                    <div class="empty-state">
                        <div class="empty-icon">∅</div>
                        <p>@L.T("Empty.Title")</p>
                        <p class="hint">@L.T("Empty.Hint")</p>
                        <button type="button" class="secondary" disabled="@Workspace.IsBusy" @onclick="LoadSampleAsync">
                            @L.T("Action.LoadSample")
                        </button>
                    </div>
                }
                else
                {
                    <table class="chapter-grid">
                        <thead>
                        <tr>
                            <th class="col-num">@L.T("Grid.Number")</th>
                            <th class="col-time">@L.T("Grid.Time")</th>
                            <th class="col-name">@L.T("Grid.Name")</th>
                            <th class="col-frames">@L.T("Grid.Frames")</th>
                        </tr>
                        </thead>
                        <tbody>
                        @for (var i = 0; i < Workspace.Rows.Count; i++)
                        {
                            var index = i;
                            var row = Workspace.Rows[i];
                            <tr class="@(row.IsSeparator ? "separator" : null) @(Workspace.IsRowSelected(index) ? "selected" : null)"
                                @onclick="e => OnRowClick(index, e)"
                                @oncontextmenu="e => OpenContextMenu(index, e)"
                                @oncontextmenu:preventDefault>
                                <td class="col-num">@(row.IsSeparator ? "—" : row.Number.ToString())</td>
                                <td class="col-time">
                                    @if (row.IsSeparator)
                                    {
                                        <span></span>
                                    }
                                    else
                                    {
                                        <input class="cell-edit"
                                               value="@row.TimeText"
                                               disabled="@Workspace.IsBusy"
                                               @onchange="e => OnTimeChanged(index, e)"
                                               @onclick:stopPropagation />
                                    }
                                </td>
                                <td class="col-name">
                                    <input class="cell-edit"
                                           value="@row.Name"
                                           disabled="@Workspace.IsBusy"
                                           @onchange="e => OnNameChanged(index, e)"
                                           @onclick:stopPropagation />
                                </td>
                                <td class="col-frames">
                                    <span class="frame-text @(row.IsFrameAccurate ? "accurate" : row.IsFrameInexact ? "inexact" : "neutral")">
                                        @(string.IsNullOrEmpty(row.FramesInfo) ? "—" : row.FramesInfo)
                                    </span>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- Bottom: export / projection options (Avalonia zone) -->
        <div class="options-zone">
            <div class="option-cell">
                <label class="option-label" for="saveFormat">@L.T("Label.SaveAs")</label>
                <select id="saveFormat"
                        @bind="saveFormatIndex"
                        @bind:after="OnExportOptionsChanged"
                        disabled="@Workspace.IsBusy">
                    @foreach (var format in Workspace.SaveFormats)
                    {
                        <option value="@format.Index">@format.DisplayName</option>
                    }
                </select>
            </div>

            <div class="option-cell option-name-mode">
                <label class="option-label" for="nameMode">@L.T("Label.ChapterName")</label>
                <div class="name-mode-controls">
                    <select id="nameMode"
                            @bind="chapterNameModeIndex"
                            @bind:after="OnProjectionOptionsChanged"
                            disabled="@Workspace.IsBusy">
                        @for (var i = 0; i < L.ChapterNameModes.Count; i++)
                        {
                            <option value="@i">@L.ChapterNameModes[i]</option>
                        }
                    </select>
                    <button type="button"
                            class="secondary template-button"
                            disabled="@Workspace.IsBusy"
                            @onclick="TriggerTemplateLoad"
                            title="@L.T("Action.BrowseTemplate")">
                        @L.T("Action.BrowseTemplate")
                    </button>
                </div>
                @if (chapterNameModeIndex == 2 || !string.IsNullOrWhiteSpace(Workspace.ChapterNameTemplateStatus))
                {
                    <span class="template-status" title="@Workspace.ChapterNameTemplateStatus">
                        @L.T("Label.TemplateStatus"): @Workspace.ChapterNameTemplateStatus
                    </span>
                }
            </div>

            <div class="option-cell">
                <label class="option-label" for="xmlLang">@L.T("Label.XmlLang")</label>
                <select id="xmlLang"
                        @bind="xmlLanguage"
                        @bind:after="OnExportOptionsChanged"
                        disabled="@(Workspace.IsBusy || !Workspace.IsXmlLanguageEnabled)">
                    @foreach (var language in Workspace.XmlLanguages)
                    {
                        <option value="@language">@language</option>
                    }
                </select>
            </div>

            <div class="option-cell">
                <label class="option-label" for="orderShift">@L.T("Label.OrderShift")</label>
                <input id="orderShift"
                       type="number"
                       min="-1000"
                       max="1000"
                       step="1"
                       @bind="orderShift"
                       @bind:after="OnProjectionOptionsChanged"
                       disabled="@Workspace.IsBusy" />
            </div>

            <div class="option-cell option-expression">
                <label class="option-label">@L.T("Label.Expression")</label>
                <label class="check">
                    <input type="checkbox"
                           checked="@applyExpression"
                           disabled="@(Workspace.IsBusy || Workspace.IsChapterGridEmpty)"
                           @onchange="OnApplyExpressionChanged" />
                    @L.T("Label.UseExpression")
                </label>
                <input class="expression-input"
                       value="@expression"
                       disabled="@(Workspace.IsBusy || !applyExpression || Workspace.IsChapterGridEmpty)"
                       spellcheck="false"
                       title="@L.T("Title.Expression")"
                       @oninput="OnExpressionInput"
                       @onchange="OnExpressionCommit" />
            </div>
        </div>
    </div>

    <!-- Status / progress strip -->
    <footer class="status-bar">
        <span class="status-text" title="@Workspace.StatusText">@Workspace.StatusText</span>
        <button type="button" class="secondary log-toggle" @onclick="OpenLogs" title="@L.T("Modal.LogTitle")">@L.T("Action.Log")</button>
        <progress class="status-progress"
                  max="1"
                  value="@(Workspace.Progress > 0 ? Workspace.Progress : 0)"
                  style="@(Workspace.IsBusy || Workspace.Progress > 0 ? null : "visibility:hidden")"></progress>
    </footer>
</div>

@if (contextMenuTarget == "load")
{
    <div class="context-menu" style="left:@contextMenuXpx; top:@contextMenuYpx" @onclick:stopPropagation>
        <button type="button" @onclick="ReloadAsync" disabled="@(!Workspace.CanReload)">@L.T("Action.Reload")</button>
        <button type="button" @onclick="TriggerAppendMpls" disabled="@(!Workspace.CanAppendMpls)">@L.T("Action.AppendMpls")</button>
    </div>
}

@if (contextMenuTarget == "row" && contextMenuIndex >= 0)
{
    <div class="context-menu" style="left:@contextMenuXpx; top:@contextMenuYpx" @onclick:stopPropagation>
        <button type="button" @onclick="SelectContextRow">@L.T("Menu.Select")</button>
        <button type="button" @onclick="InsertContextRow">@L.T("Menu.Insert")</button>
        <button type="button" @onclick="DuplicateContextRow">@L.T("Menu.Duplicate")</button>
        <button type="button" @onclick="CopyContextRow">@L.T("Menu.CopyRow")</button>
        <button type="button" @onclick="CopyContextName">@L.T("Menu.CopyName")</button>
        <button type="button" @onclick="CopyContextZones" disabled="@(Workspace.FramesPerSecond <= 0 || !Workspace.HasRowSelection)">@L.T("Menu.CopyZones")</button>
        <button type="button" @onclick="PreviewFromMenu" disabled="@(!Workspace.CanPreview)">@L.T("Menu.Preview")</button>
        <button type="button" @onclick="ZonesFromMenu" disabled="@(Workspace.FramesPerSecond <= 0 || !Workspace.HasRowSelection)">@L.T("Menu.Zones")</button>
        <button type="button" @onclick="OpenForwardModal" disabled="@(!Workspace.CanRefreshRows)">@L.T("Menu.ForwardTranslation")</button>
        <button type="button" @onclick="OpenRelatedMedia" disabled="@(!Workspace.CanOpenRelatedMedia)">@L.T("Menu.RelatedMedia")</button>
        <button type="button" class="danger" @onclick="DeleteContextRow" disabled="@(!Workspace.HasRowSelection)">@L.T("Menu.Delete")</button>
    </div>
}

@if (contextMenuTarget == "clip")
{
    <div class="context-menu" style="left:@contextMenuXpx; top:@contextMenuYpx" @onclick:stopPropagation>
        <button type="button"
                @onclick="ToggleClipCombineContext"
                disabled="@(!Workspace.CanToggleClipCombine)">
            @(Workspace.IsClipCombined ? L.T("Menu.Split") : L.T("Menu.Combine"))
        </button>
    </div>
}

@if (contextMenuTarget == "fps")
{
    <div class="context-menu" style="left:@contextMenuXpx; top:@contextMenuYpx" @onclick:stopPropagation>
        <button type="button"
                @onclick="ChangeFrameRateContext"
                disabled="@(!Workspace.CanChangeSelectedFrameRate)">@L.T("Menu.ChangeFps")</button>
    </div>
}

@if (showLogModal)
{
    <div class="modal-backdrop" @onclick="CloseLogs">
        <section class="modal-dialog log-modal" role="dialog" aria-modal="true" aria-labelledby="log-title" @onclick:stopPropagation>
            <header class="modal-header">
                <h2 id="log-title">@L.T("Modal.LogTitle")</h2>
                <button type="button" class="modal-close" @onclick="CloseLogs" title="@L.T("Action.Close")">×</button>
            </header>
            <div class="modal-body log-list">
                @if (Workspace.Logs.Count == 0)
                {
                    <span class="log-empty">@L.T("Modal.LogEmpty")</span>
                }
                else
                {
                    @foreach (var entry in Workspace.Logs.Reverse())
                    {
                        <div class="log-entry">
                            <time>@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</time>
                            <span class="log-level @entry.Level.ToLowerInvariant()">@entry.Level</span>
                            <span title="@entry.Details">@entry.Message</span>
                        </div>
                    }
                }
            </div>
            <footer class="modal-footer">
                <button type="button" class="secondary" @onclick="Workspace.ClearLogs">@L.T("Action.Clear")</button>
                <button type="button" class="secondary" @onclick="CloseLogs">@L.T("Action.Close")</button>
            </footer>
        </section>
    </div>
}

@if (showPreviewModal)
{
    <div class="modal-backdrop" @onclick="ClosePreview">
        <section class="modal-dialog preview-modal" role="dialog" aria-modal="true" aria-labelledby="preview-title" @onclick:stopPropagation>
            <header class="modal-header">
                <h2 id="preview-title">@L.T("Modal.PreviewTitle")</h2>
                <button type="button" class="modal-close" @onclick="ClosePreview" title="@L.T("Action.Close")">×</button>
            </header>
            <div class="modal-body">
                <pre class="preview-text">@previewText</pre>
            </div>
            <footer class="modal-footer">
                <button type="button" class="secondary" @onclick="CopyPreviewAsync" disabled="@(previewText.Length == 0)">@L.T("Action.Copy")</button>
                <button type="button" class="secondary" @onclick="DownloadPreviewAsync" disabled="@(previewText.Length == 0)">@L.T("Action.Download")</button>
                <span class="modal-spacer"></span>
                <button type="button" class="secondary" @onclick="ClosePreview">@L.T("Action.Close")</button>
            </footer>
        </section>
    </div>
}

@if (showForwardModal)
{
    <div class="modal-backdrop" @onclick="CloseForwardModal">
        <section class="modal-dialog forward-modal" role="dialog" aria-modal="true" aria-labelledby="forward-title" @onclick:stopPropagation>
            <header class="modal-header">
                <h2 id="forward-title">@L.T("Modal.ForwardTitle")</h2>
                <button type="button" class="modal-close" @onclick="CloseForwardModal" title="@L.T("Action.Close")">×</button>
            </header>
            <div class="modal-body">
                <div class="settings-grid">
                    <label for="forward-frames">@L.T("Modal.Frames")</label>
                    <input id="forward-frames" type="number" min="1" max="100000" step="1" @bind="forwardFrames" />
                </div>
            </div>
            <footer class="modal-footer">
                <button type="button" class="secondary" @onclick="CloseForwardModal">@L.T("Action.Cancel")</button>
                <button type="button" class="secondary" @onclick="ApplyForwardShift">@L.T("Modal.ApplyShift")</button>
            </footer>
        </section>
    </div>
}

@if (showRelatedModal)
{
    <div class="modal-backdrop" @onclick="CloseRelatedModal">
        <section class="modal-dialog related-modal" role="dialog" aria-modal="true" aria-labelledby="related-title" @onclick:stopPropagation>
            <header class="modal-header">
                <h2 id="related-title">@L.T("Modal.RelatedTitle")</h2>
                <button type="button" class="modal-close" @onclick="CloseRelatedModal" title="@L.T("Action.Close")">×</button>
            </header>
            <div class="modal-body">
                @if (Workspace.RelatedMediaReferences.Count == 0)
                {
                    <p class="settings-note">@L.T("Status.NoRelatedMedia")</p>
                }
                else
                {
                    <ul class="related-list">
                        @foreach (var media in Workspace.RelatedMediaReferences)
                        {
                            <li>
                                <strong>@media.DisplayName</strong>
                                <div class="related-path">
                                    @L.T("Related.Relative"):
                                    @if (!string.IsNullOrWhiteSpace(media.RelativePath))
                                    {
                                        <a href="@media.RelativePath" target="_blank" rel="noopener">@media.RelativePath</a>
                                    }
                                    else
                                    {
                                        <code>—</code>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(media.AbsolutePath))
                                {
                                    <div class="related-path">@L.T("Related.Absolute"): <code>@media.AbsolutePath</code></div>
                                }
                            </li>
                        }
                    </ul>
                    <p class="settings-note">@L.T("Related.BrowserLimit")</p>
                }
            </div>
            <footer class="modal-footer">
                <button type="button" class="secondary" @onclick="CloseRelatedModal">@L.T("Action.Close")</button>
            </footer>
        </section>
    </div>
}

@if (showSettingsModal)
{
    <div class="modal-backdrop" @onclick="CancelSettings">
        <section class="modal-dialog settings-modal" role="dialog" aria-modal="true" aria-labelledby="settings-title" @onclick:stopPropagation>
            <header class="modal-header">
                <h2 id="settings-title">@L.T("Modal.SettingsTitle")</h2>
                <button type="button" class="modal-close" @onclick="CancelSettings" title="@L.T("Action.Close")">×</button>
            </header>
            <nav class="settings-tabs" aria-label="@L.T("Modal.SettingsTitle")">
                @for (var tab = 0; tab < L.SettingsTabs.Count; tab++)
                {
                    var tabIndex = tab;
                    <button type="button"
                            class="settings-tab @(settingsTab == tabIndex ? "active" : null)"
                            @onclick="() => settingsTab = tabIndex">@L.SettingsTabs[tabIndex]</button>
                }
            </nav>
            <div class="modal-body settings-page">
                @if (settingsTab == 0)
                {
                    <h3>@L.T("Settings.General")</h3>
                    <div class="settings-grid">
                        <label for="settings-ui-language">@L.T("Settings.UiLanguage")</label>
                        <select id="settings-ui-language" @bind="draftUiLanguage">
                            @foreach (var language in UiLanguages)
                            {
                                <option value="@language.Code">@language.DisplayName</option>
                            }
                        </select>
                        <label for="settings-save-directory">@L.T("Settings.SaveDirectory")</label>
                        <input id="settings-save-directory" value="@L.T("Settings.SaveDirectoryValue")" disabled title="@L.T("Settings.SaveDirectoryNote")" />
                    </div>
                    <p class="settings-note">@L.T("Settings.SaveDirectoryNote")</p>
                }
                else if (settingsTab == 1)
                {
                    <h3>@L.T("Settings.Tools")</h3>
                    <div class="settings-grid settings-disabled-page">
                        @foreach (var tool in ExternalToolIds)
                        {
                            <label for="tool-@tool">@L.T($"Tool.{tool}")</label>
                            <div class="tool-setting">
                                <input id="tool-@tool" value="@L.T("Settings.ToolUnavailable")" disabled />
                                <span>@L.T("Settings.ToolNote")</span>
                            </div>
                        }
                    </div>
                    <button type="button" class="secondary" disabled title="@L.T("Settings.ToolUnavailable")">@L.T("Settings.ValidateTools")</button>
                }
                else if (settingsTab == 2)
                {
                    <h3>@L.T("Settings.Output")</h3>
                    <div class="settings-grid">
                        <label for="settings-save-format">@L.T("Settings.DefaultSaveFormat")</label>
                        <select id="settings-save-format" @bind="draftSaveFormatIndex">
                            @foreach (var format in Workspace.SaveFormats)
                            {
                                <option value="@format.Index">@format.DisplayName</option>
                            }
                        </select>
                        <label for="settings-xml-language">@L.T("Settings.DefaultXmlLanguage")</label>
                        <select id="settings-xml-language" @bind="draftXmlLanguage">
                            @foreach (var language in Workspace.XmlLanguages)
                            {
                                <option value="@language">@language</option>
                            }
                        </select>
                        <label for="settings-encoding">@L.T("Settings.TextEncoding")</label>
                        <select id="settings-encoding" @bind="draftOutputTextEncodingIndex">
                            @for (var encodingIndex = 0; encodingIndex < OutputTextEncodings.All.Count; encodingIndex++)
                            {
                                <option value="@encodingIndex">@OutputTextEncodings.DisplayName(OutputTextEncodings.All[encodingIndex])</option>
                            }
                        </select>
                        <label>@L.T("Settings.EmitBom")</label>
                        <label class="settings-check"><input type="checkbox" @bind="draftEmitBom" /> @L.T("Settings.EmitBomLabel")</label>
                        <label for="settings-tolerance">@L.T("Settings.Tolerance")</label>
                        <div class="range-setting">
                            <input id="settings-tolerance" type="range" min="0.01" max="0.30" step="0.01" @bind="draftFrameAccuracyTolerance" />
                            <output>@draftFrameAccuracyTolerance.ToString("0.##")</output>
                        </div>
                    </div>
                }
                else if (settingsTab == 3)
                {
                    <h3>@L.T("Settings.Appearance")</h3>
                    <div class="settings-grid">
                        <label for="settings-theme">@L.T("Settings.Preset")</label>
                        <select id="settings-theme" @bind="draftThemePresetId">
                            @foreach (var theme in ThemeOptions)
                            {
                                <option value="@theme.Id">@theme.DisplayName</option>
                            }
                        </select>
                        <label>@L.T("Settings.Preview")</label>
                        <div class="theme-swatches">
                            @foreach (var swatch in SelectedTheme.PreviewSwatches)
