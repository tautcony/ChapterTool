        Workspace.XmlLanguage = xmlLanguage;
        Workspace.TextEncoding = OutputTextEncodings.All[Math.Clamp(outputTextEncodingIndex, 0, OutputTextEncodings.All.Count - 1)];
        Workspace.EmitBom = emitBom;
        Workspace.FrameAccuracyTolerance = frameAccuracyTolerance;
