    private void OpenContextMenu(int index, MouseEventArgs args)
    {
        contextMenuTarget = "row";
        contextMenuIndex = index;
        contextMenuXpx = $"{args.ClientX}px";
        contextMenuYpx = $"{args.ClientY}px";
        Workspace.EnsureRowSelected(index);
    }

    private void OpenClipContextMenu(MouseEventArgs args)
    {
        contextMenuTarget = "clip";
        contextMenuIndex = -1;
        contextMenuXpx = $"{args.ClientX}px";
        contextMenuYpx = $"{args.ClientY}px";
    }

    private void OpenFrameRateContextMenu(MouseEventArgs args)
    {
        contextMenuTarget = "fps";
        contextMenuIndex = -1;
        contextMenuXpx = $"{args.ClientX}px";
        contextMenuYpx = $"{args.ClientY}px";
    }

    private void CloseContextMenu()
    {
        contextMenuTarget = null;
        contextMenuIndex = -1;
    }

    private void OnShellClick()
    {
        if (contextMenuTarget is not null)
        {
            CloseContextMenu();
        }
    }

    private void ToggleClipCombineContext()
    {
        Workspace.ToggleClipCombine();
        CloseContextMenu();
    }

    private void ChangeFrameRateContext()
    {
        Workspace.ChangeSelectedFrameRate();
        CloseContextMenu();
    }

    private void SelectContextRow()
    {
        Workspace.SelectRow(contextMenuIndex);
        CloseContextMenu();
    }

    private void InsertContextRow()
    {
        Workspace.InsertBefore(contextMenuIndex);
        CloseContextMenu();
    }

    private void DuplicateContextRow()
    {
        Workspace.DuplicateRow(contextMenuIndex);
        CloseContextMenu();
    }

    private void DeleteContextRow()
    {
        Workspace.DeleteSelectedRows();
        CloseContextMenu();
    }

    private async Task CopyContextRow() => await CopyTextAsync(Workspace.SelectedRowsText(), L.T("Copy.Row"));

    private async Task CopyContextName() => await CopyTextAsync(Workspace.SelectedRowsText(includeTime: false), L.T("Copy.Name"));

    private async Task CopyContextZones()
    {
        var zones = Workspace.CreateZonesForSelection();
        if (zones.Length > 0)
        {
            await CopyTextAsync(zones, L.T("Copy.Zones"));
        }

        CloseContextMenu();
    }

    private async Task ZonesFromMenu()
    {
        await CopyContextZones();
    }

    private void OpenForwardModal()
    {
        CloseContextMenu();
        forwardFrames = 1;
        showForwardModal = true;
    }

    private void CloseForwardModal() => showForwardModal = false;

    private void ApplyForwardShift()
    {
        Workspace.ShiftFramesForward(forwardFrames);
        showForwardModal = false;
    }

    private void OpenRelatedMedia()
    {
        CloseContextMenu();
        if (!Workspace.CanOpenRelatedMedia)
        {
            Workspace.SetStatusMessage(L.T("Status.NoRelatedMedia"));
            Workspace.RecordAction(L.T("Status.NoRelatedMedia"));
            return;
        }

        showRelatedModal = true;
        Workspace.RecordAction(L.T("Status.RelatedMediaNote"));
    }

    private void CloseRelatedModal() => showRelatedModal = false;

    private async Task CopyTextAsync(string text, string action)
    {
        if (text.Length > 0)
        {
            await Js.InvokeVoidAsync("chapterToolWasm.copyText", text);
            Workspace.RecordAction(action);
        }

        CloseContextMenu();
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs args)
    {
        var typing = false;
        try
        {
            typing = await Js.InvokeAsync<bool>("chapterToolWasm.isEditableTarget");
        }
        catch (JSException)
        {
            typing = false;
        }

        if (typing)
        {
            return;
        }

        if (showSettingsModal || showLogModal || showPreviewModal || showForwardModal || showRelatedModal)
        {
            if (args.Key is "Escape")
            {
                showSettingsModal = false;
                showLogModal = false;
                showPreviewModal = false;
                showForwardModal = false;
                showRelatedModal = false;
                CloseContextMenu();
            }

            return;
        }

        var key = args.Key;
        var ctrl = args.CtrlKey || args.MetaKey;
        if (ctrl && string.Equals(key, "o", StringComparison.OrdinalIgnoreCase))
        {
            await TriggerLoad();
            return;
        }

        if (ctrl && string.Equals(key, "s", StringComparison.OrdinalIgnoreCase))
        {
            await SaveAsync();
            return;
        }

        if ((ctrl && string.Equals(key, "r", StringComparison.OrdinalIgnoreCase)) || string.Equals(key, "F5", StringComparison.OrdinalIgnoreCase))
        {
            await ReloadAsync();
            return;
        }

        if (string.Equals(key, "F11", StringComparison.OrdinalIgnoreCase))
        {
            await PreviewAsync();
            return;
        }

        if (ctrl && string.Equals(key, "l", StringComparison.OrdinalIgnoreCase))
        {
            OpenLogs();
            return;
        }

        if (!ctrl && string.Equals(key, "F9", StringComparison.OrdinalIgnoreCase))
        {
            RefreshRows();
        }
    }
}
