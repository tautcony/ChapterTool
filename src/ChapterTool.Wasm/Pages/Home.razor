            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            PushExportOptions();
            PushProjectionOptions();
            await Workspace.AppendMplsAsync(file.Name, memory.ToArray());
            PullOptionsFromWorkspace();
