    private async Task ApplySettingsAsync()
    {
        var settings = CreateSettingsDocumentFromDraft();
        ApplySettingsToWorkspace(settings);
        ApplySessionDraft();
        await ApplyAppearanceAsync();
        await PersistSettingsAsync();
        showSettingsModal = false;
        StateHasChanged();
    }

    private void ApplySettingsToWorkspace(WasmSettings settings)
    {
        var application = settings.Application ?? new WasmApplicationSettings();
        var theme = settings.Theme ?? new WasmThemeSettings();
        var font = settings.Font ?? new WasmFontSettings();
        var parsedFormat = Enum.TryParse<ChapterExportFormat>(application.DefaultSaveFormat, true, out var format)
            ? format
            : ChapterExportFormat.Txt;

        saveFormatIndex = Math.Clamp(ChapterExportFormats.IndexOf(parsedFormat), 0, Math.Max(0, Workspace.SaveFormats.Count - 1));
        xmlLanguage = Workspace.XmlLanguages.Contains(application.DefaultXmlLanguage, StringComparer.OrdinalIgnoreCase)
            ? application.DefaultXmlLanguage
            : Workspace.XmlLanguages.FirstOrDefault("und");
        uiLanguage = UiLanguages.Any(language => string.Equals(language.Code, application.Language, StringComparison.OrdinalIgnoreCase))
            ? application.Language
            : "en-US";
        L.SetCulture(uiLanguage);
        outputTextEncodingIndex = Math.Max(0, OutputTextEncodings.All.ToList().IndexOf(OutputTextEncodings.ParseOrDefault(application.OutputTextEncoding)));
        emitBom = application.EmitBom;
        frameAccuracyTolerance = Math.Clamp(application.FrameAccuracyTolerance <= 0 ? 0.15m : application.FrameAccuracyTolerance, 0.01m, 0.30m);
        themePresetId = ThemeOptions.Any(option => string.Equals(option.Id, theme.PresetId, StringComparison.OrdinalIgnoreCase))
            ? theme.PresetId
            : "avalonia-default";
        uiFontFamily = string.IsNullOrWhiteSpace(font.UiFontFamily) ? "system-ui" : font.UiFontFamily;
        monospaceFontFamily = string.IsNullOrWhiteSpace(font.MonospaceFontFamily)
            ? "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
            : font.MonospaceFontFamily;
        PushExportOptions();
        Workspace.ApplyOptionsAndRefresh();
    }

    private async Task PersistSettingsAsync()
    {
        var settings = CreateSettingsDocument();
        await Js.InvokeVoidAsync("chapterToolWasm.setLocalStorage", SettingsStorageKey, JsonSerializer.Serialize(settings, SettingsJsonOptions));
    }

    private WasmSettings CreateSettingsDocumentFromDraft() =>
        new(
            SchemaVersion: 1,
            Application: new WasmApplicationSettings(
                Language: draftUiLanguage,
                DefaultSaveFormat: ChapterExportFormats.AtIndex(draftSaveFormatIndex).ToString(),
                DefaultXmlLanguage: draftXmlLanguage,
                OutputTextEncoding: OutputTextEncodings.Id(OutputTextEncodings.All[Math.Clamp(draftOutputTextEncodingIndex, 0, OutputTextEncodings.All.Count - 1)]),
                EmitBom: draftEmitBom,
                FrameAccuracyTolerance: draftFrameAccuracyTolerance),
            Theme: new WasmThemeSettings(draftThemePresetId),
            Font: new WasmFontSettings(
                UiFontFamily: draftUiFontFamily == "system-ui" ? string.Empty : draftUiFontFamily,
                MonospaceFontFamily: draftMonospaceFontFamily == "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace" ? string.Empty : draftMonospaceFontFamily));

    private WasmSettings CreateSettingsDocument() =>
        new(
            SchemaVersion: 1,
            Application: new WasmApplicationSettings(
                Language: uiLanguage,
                DefaultSaveFormat: ChapterExportFormats.AtIndex(saveFormatIndex).ToString(),
                DefaultXmlLanguage: xmlLanguage,
                OutputTextEncoding: Workspace.OutputTextEncodingId,
                EmitBom: emitBom,
                FrameAccuracyTolerance: frameAccuracyTolerance),
            Theme: new WasmThemeSettings(themePresetId),
            Font: new WasmFontSettings(
                UiFontFamily: uiFontFamily == "system-ui" ? string.Empty : uiFontFamily,
                MonospaceFontFamily: monospaceFontFamily == "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace" ? string.Empty : monospaceFontFamily));

    private void ApplySessionDraft()
    {
        chapterNameModeIndex = Math.Clamp(draftChapterNameModeIndex, 0, 2);
        orderShift = Math.Max(0, draftOrderShift);
        selectedFrameRateIndex = Math.Max(0, draftFrameRateIndex);
        applyExpression = draftApplyExpression;
        expression = string.IsNullOrWhiteSpace(draftExpression) ? "t" : draftExpression.Trim();
        roundFrames = draftRoundFrames;
        PushProjectionOptions();
        Workspace.SelectedFrameRateIndex = selectedFrameRateIndex;
        Workspace.PreferredFrameRateIndex = selectedFrameRateIndex;
        Workspace.ApplyOptionsAndRefresh();
    }

    private async Task ApplyAppearanceAsync()
    {
        await Js.InvokeVoidAsync("chapterToolWasm.applyAppearance", themePresetId, uiLanguage, uiFontFamily, monospaceFontFamily);
    }

    private void OpenLoadContextMenu(MouseEventArgs args)
