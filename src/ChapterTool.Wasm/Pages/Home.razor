        Workspace.SetStatusMessage(L.T("Status.Ready"));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        dropZoneRef = DotNetObjectReference.Create(this);
        await Js.InvokeVoidAsync("chapterToolWasm.registerDropZone", "chaptertool-shell", dropZoneRef);

        string? json = await Js.InvokeAsync<string?>("chapterToolWasm.getLocalStorage", SettingsStorageKey);
        if (string.IsNullOrWhiteSpace(json))
        {
            foreach (var legacyKey in LegacySettingsStorageKeys)
            {
                var legacyJson = await Js.InvokeAsync<string?>("chapterToolWasm.getLocalStorage", legacyKey);
                if (!string.IsNullOrWhiteSpace(legacyJson))
                {
                    json = legacyJson;
                    await Js.InvokeVoidAsync("chapterToolWasm.setLocalStorage", SettingsStorageKey, legacyJson);
                    break;
                }
            }
        }

        foreach (var legacyKey in LegacySettingsStorageKeys)
        {
            await Js.InvokeVoidAsync("chapterToolWasm.removeLocalStorage", legacyKey);
        }

        if (!string.IsNullOrWhiteSpace(json))
        {
            try
            {
                var settings = JsonSerializer.Deserialize<WasmSettings>(json, SettingsJsonOptions);
                if (settings is { SchemaVersion: 1, Application: not null, Theme: not null, Font: not null })
                {
                    ApplySettingsToWorkspace(settings);
                    await ApplyAppearanceAsync();
                    PullOptionsFromWorkspace();
                    StateHasChanged();
                }
                else
                {
                    await Js.InvokeVoidAsync("chapterToolWasm.removeLocalStorage", SettingsStorageKey);
                }
            }
            catch (JsonException)
            {
                await Js.InvokeVoidAsync("chapterToolWasm.removeLocalStorage", SettingsStorageKey);
            }
        }
    }

    public void Dispose()
    {
        Workspace.Changed -= OnWorkspaceChanged;
        L.CultureChanged -= OnCultureChanged;
        dropZoneRef?.Dispose();
    }

    [JSInvokable]
    public void OnDragStateChanged(bool over)
    {
        if (isDragOver == over)
        {
            return;
        }

        isDragOver = over;
        if (over)
        {
            Workspace.SetStatusMessage(L.T("Status.DropReady"));
        }

        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnBrowserFileDropped(string name, byte[] bytes)
    {
        isDragOver = false;
        CloseContextMenu();
        if (string.IsNullOrWhiteSpace(name) || bytes is null || bytes.Length == 0)
        {
            Workspace.SetStatusMessage(L.T("Status.DropEmpty"));
            Workspace.RecordAction(L.T("Status.DropEmpty"));
            StateHasChanged();
            return;
        }

        if (bytes.LongLength > WasmWorkspace.MaxLoadBytes)
        {
            Workspace.SetStatusMessage(L.T("Status.DropTooLarge"));
            Workspace.RecordAction(L.T("Status.DropTooLarge"));
            StateHasChanged();
            return;
        }

        PushExportOptions();
        PushProjectionOptions();
        await Workspace.LoadAsync(name, bytes);
        PullOptionsFromWorkspace();
        StateHasChanged();
    }

    [JSInvokable]
    public void OnBrowserFileDropRejected(string reason)
    {
        isDragOver = false;
        var message = string.Equals(reason, "too-large", StringComparison.OrdinalIgnoreCase)
            ? L.T("Status.DropTooLarge")
            : L.T("Status.DropBlocked");
        Workspace.SetStatusMessage(message);
        Workspace.RecordAction(message);
        StateHasChanged();
    }

    private void OnWorkspaceChanged() => InvokeAsync(() =>
