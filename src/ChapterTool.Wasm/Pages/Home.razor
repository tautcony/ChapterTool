    private async Task OnTemplateSelected(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            using var reader = new StreamReader(stream, Encoding.UTF8, detectEncodingFromByteOrderMarks: true);
            var text = await reader.ReadToEndAsync();
            if (Workspace.SetChapterNameTemplate(file.Name, text))
            {
                chapterNameModeIndex = 2;
                PullOptionsFromWorkspace();
            }
        }
        catch (Exception)
        {
            Workspace.SetStatusMessage(L.T("Status.TemplateFailed"));
            Workspace.RecordAction(L.T("Status.TemplateFailed"));
        }
    }

    private async Task LoadFileAsync(IBrowserFile file)
    {
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: WasmWorkspace.MaxLoadBytes);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            PushExportOptions();
            PushProjectionOptions();
            await Workspace.LoadAsync(file.Name, memory.ToArray());
            PullOptionsFromWorkspace();
        }
        catch (IOException)
        {
            Workspace.SetStatusMessage(L.T("Status.DropTooLarge"));
            Workspace.RecordAction(L.T("Status.DropTooLarge"));
        }
        catch (Exception ex)
        {
            Workspace.SetStatusMessage(ex.Message);
            await Js.InvokeVoidAsync("console.error", ex.Message);
        }
    }

    private async Task AppendMplsFileAsync(IBrowserFile file)
