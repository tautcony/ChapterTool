                        </div>
                        <label for="settings-mono-font">@L.T("Settings.MonoFont")</label>
                        <div class="font-setting">
                            <select id="settings-mono-font" @bind="draftMonospaceFontFamily">
                                @foreach (var font in MonospaceFontOptions)
                                {
                                    <option value="@font.Value">@font.Name</option>
                                }
                            </select>
                            <div class="font-preview mono-preview" style="font-family:@draftMonospaceFontFamily">00:00:00.000  Chapter</div>
                        </div>
                    </div>
                }
                else
                {
                    <h3>@L.T("Settings.About")</h3>
                    <div class="about-body">
                        <p>@L.T("Settings.AboutBody")</p>
                        <p class="settings-note">@L.T("Settings.AboutRuntime")</p>
                        <p class="settings-note">@L.T("Settings.AboutLicense")</p>
                        <a href="https://github.com/tautcony/ChapterTool" target="_blank" rel="noreferrer">github.com/tautcony/ChapterTool</a>
                    </div>
                }
            </div>
            <footer class="modal-footer">
                <button type="button" class="secondary" @onclick="ResetSettings">@L.T("Action.RestoreDefaults")</button>
                <span class="modal-spacer"></span>
                <button type="button" class="secondary" @onclick="CancelSettings">@L.T("Action.Cancel")</button>
                <button type="button" class="secondary" @onclick="ApplySettingsAsync">@L.T("Action.Apply")</button>
            </footer>
        </section>
    </div>
}

