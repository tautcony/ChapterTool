        draftExpression = "t";
        draftRoundFrames = true;
        draftUiLanguage = "en-US";
        draftOutputTextEncodingIndex = 0;
        draftEmitBom = true;
        draftFrameAccuracyTolerance = 0.15m;
        draftThemePresetId = "avalonia-default";
