<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChapterTool.Avalonia.ViewModels"
             xmlns:tools="clr-namespace:ChapterTool.Avalonia.ViewModels.Tools"
             x:Class="ChapterTool.Avalonia.Views.Tools.ForwardShiftToolView"
             x:DataType="tools:ForwardShiftToolViewModel"
             x:CompileBindings="True">
  <StackPanel Margin="16" Spacing="10">
    <TextBlock Text="{DynamicResource Tool.ForwardShift.Title}" FontSize="18" />
    <NumericUpDown Minimum="-1000000" Maximum="1000000" Increment="1" Value="{Binding Frames}" />
    <Button Content="{DynamicResource Common.Apply}" MinWidth="80" HorizontalAlignment="Left" Command="{Binding ApplyCommand}" CommandParameter="{Binding}" />
  </StackPanel>
</UserControl>
