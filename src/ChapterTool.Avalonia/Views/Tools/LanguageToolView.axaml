<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ChapterTool.Avalonia.ViewModels"
             x:Class="ChapterTool.Avalonia.Views.Tools.LanguageToolView"
             x:DataType="vm:LanguageToolViewModel"
             x:CompileBindings="True">
  <StackPanel Margin="16" Spacing="10">
    <TextBlock Text="Language" FontSize="18" />
    <ComboBox SelectedIndex="{Binding SelectedLanguageIndex}">
      <ComboBoxItem Content="Default" Tag="" />
      <ComboBoxItem Content="en-US" Tag="en-US" />
    </ComboBox>
    <Button Content="Apply" MinWidth="80" HorizontalAlignment="Left" Command="{Binding ApplyCommand}" CommandParameter="{Binding}" />
  </StackPanel>
</UserControl>
