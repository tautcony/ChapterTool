{
  "name": "@chaptertool/node",
  "version": "23.2.0",
  "description": "Portable ChapterTool Core API for Node.js through .NET WebAssembly.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || >=24.0.0"
  },
  "scripts": {
    "doctor": "node ./scripts/check-environment.mjs",
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run build && vitest run",
    "test:built": "vitest run",
    "pack:verify": "node ./scripts/verify-pack.mjs",
    "prepack": "npm run build"
  },
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tautcony/ChapterTool.git"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "fs-extra": "^11.3.6",
    "tsdown": "^0.22.13",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
